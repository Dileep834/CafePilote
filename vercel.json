{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.cafepilots.com" }],
      "destination": "https://cafepilots.com/:path*",
      "permanent": true
    },
    {
      "source": "/login",
      "has": [{ "type": "host", "value": "app.cafepilots.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/app",
      "has": [{ "type": "host", "value": "app.cafepilots.com" }],
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
