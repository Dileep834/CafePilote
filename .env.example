# Copy to .env for local development. On Vercel, add the same keys
# under Project Settings → Environment Variables, then redeploy.
# Owner: Dileep834 / CafePilote

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# QR guest login uses Supabase Auth -> Google provider.
# The client ID is public; keep the client secret only in Supabase or an ignored
# client_secret_*.json file, never in VITE_* frontend variables.
VITE_GOOGLE_CLIENT_ID=481368245950-64l9ksc8o29119mln2ur4d592bt6r8oi.apps.googleusercontent.com
