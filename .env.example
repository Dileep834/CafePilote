# Copy to .env for local development. On Vercel, add the same keys
# under Project Settings -> Environment Variables, then redeploy.
# Owner: Dileep834 / CafePilote

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only API keys for payment gateway settings.
# Never expose SUPABASE_SERVICE_ROLE_KEY in frontend VITE_* variables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# QR guest login uses Supabase Auth -> Google provider.
# The client ID is public; keep the client secret only in Supabase or an ignored
# client_secret_*.json file, never in VITE_* frontend variables.
VITE_GOOGLE_CLIENT_ID=481368245950-64l9ksc8o29119mln2ur4d592bt6r8oi.apps.googleusercontent.com

# Optional platform fallback values. Outlet admins can override these per branch
# from Settings -> Payment Gateways after running scripts/payment_gateway_settings_schema.sql.
# Do not prefix secrets with VITE_.
#
# Use PAYMENT_GATEWAY_MODE=sandbox until each provider has approved production.
PAYMENT_GATEWAY_MODE=sandbox
PAYMENT_PUBLIC_BASE_URL=https://cafepilots.com

# Paytm JS Checkout
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CALLBACK_URL=https://cafepilots.com/api/payment-gateways/callback?gateway=paytm

# PhonePe Standard Checkout
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_VERSION=
PHONEPE_CLIENT_SECRET=
PHONEPE_REDIRECT_URL=https://cafepilots.com/erp/pos/checkout

# Amazon Pay Checkout v2
AMAZON_PAY_PUBLIC_KEY_ID=
AMAZON_PAY_STORE_ID=
AMAZON_PAY_PRIVATE_KEY_PATH=
AMAZON_PAY_PRIVATE_KEY=
AMAZON_PAY_REGION=eu
AMAZON_PAY_SANDBOX=true
